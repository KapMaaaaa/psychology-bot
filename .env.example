# Copy to .env and fill in real values. Do not commit .env.

# --- OpenAI ---
OPENAI_API_KEY=

# --- Email (SMTP / fastapi-mail) ---
# Gmail: smtp.gmail.com, port 587, MAIL_STARTTLS=true, MAIL_SSL_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
# Optional display name shown to recipients
MAIL_FROM_NAME=
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
# Set to 1 to skip SMTP (logs code only; for local dev without credentials)
MAIL_SUPPRESS_SEND=0

# Return verification code in API JSON for debugging only (never in production)
DEV_RETURN_VERIFICATION_CODE=0

# --- Database ---
DATABASE_URL=sqlite:///./app.db
DROP_EXISTING_TABLES=false

# --- App ---
FRONTEND_URL=http://localhost:3000
SECRET_KEY=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
